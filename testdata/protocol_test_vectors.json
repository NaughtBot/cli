{
  "description": "Protocol-level test vectors for SSH SK signing and response formats",
  "ssh_sk": {
    "description": "SSH Security Key (sk-ecdsa-sha2-nistp256@openssh.com) protocol test vectors",
    "message_construction": [
      {
        "description": "Standard SSH authentication with empty challenge",
        "application": "ssh:",
