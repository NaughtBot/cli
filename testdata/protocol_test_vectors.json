        "flags": 1,
        "counter": 1,
        "expected_message_hex": "e30610e8a162115960fe1ec223e6529c9f4b6e80200dcb5e5c321c8af1e2b1bf0100000001e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "expected_message_length": 69
      },
      {
        "description": "SSH authentication with Hello World challenge",
        "application": "ssh:",
        "application_hash_hex": "e30610e8a162115960fe1ec223e6529c9f4b6e80200dcb5e5c321c8af1e2b1bf",
        "data_hex": "48656c6c6f2c20576f726c6421",
