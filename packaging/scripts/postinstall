#!/bin/bash
# NaughtBot CLI Post-Install Script

set -e

# Ensure executables have correct permissions
chmod 755 /usr/local/bin/nb
chmod 755 /usr/local/bin/age-plugin-nb
chmod 755 /usr/local/lib/libnb-sk.dylib
chmod 755 /usr/local/lib/libnb-pkcs11.dylib

# Log installation
logger "NaughtBot CLI installed successfully"

exit 0
